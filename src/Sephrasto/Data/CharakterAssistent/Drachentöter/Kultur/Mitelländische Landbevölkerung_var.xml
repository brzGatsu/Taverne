<Charakter>
  <Varianten>
    <Variante name="Küstengebiete oder an großen Flüssen">
	  <Fertigkeit name="Athletik" wert="1"/>
	  <Fertigkeit name="Naturkunde" wert="1"/>
	  <Fertigkeit name="Seefahrt" wert="1"/>
    </Variante>
	<Variante name="An einer wichtigen Handelsroute/Reichsstraße">
	  <Fertigkeit name="Diplomatie" wert="1"/>
	  <Fertigkeit name="Feingefühl" wert="1"/>
	  <Fertigkeit name="Naturkunde" wert="1"/>
	  <Fertigkeit name="Mythenkunde" wert="1"/>
	  <Fertigkeit name="Tierführung" wert="1"/>
    </Variante>
    <Variante name="Regionen Weiden und Greifenfurt">
	  
	  <Fertigkeit name="Überleben" wert="1"/>
	  <Fertigkeit name="Grobhandwerk" wert="1"/>
    </Variante>
	<Variante name="Gebirge">
	  <Fertigkeit name="Athletik" wert="1"/>
	  <Fertigkeit name="Überleben" wert="1"/>
    </Variante>
    <Variante name="Fern der Zivilisation">
	  <Fertigkeit name="Athletik" wert="1"/>
	  <Fertigkeit name="Feingefühl" wert="-1"/>
	  <Fertigkeit name="Beeinflussung" wert="-1"/>
	  <Fertigkeit name="Jagd" wert="1"/>
	  <Fertigkeit name="Naturkunde" wert="1"/>
	  <Fertigkeit name="Überleben" wert="2"/>
    </Variante>
	<Variante name="Landadel">
	  <Vorteil name="Privilegien (Adel)"/>
	  <Fertigkeit name="Tierführung" wert="1"/>
	  <Fertigkeit name="Diplomatie" wert="1"/>
	  <Vorteil name="Schriftkenntnis (Kusliker Zeichen)"/>
    </Variante>
    <Variante name="Jilaskan">
      <Fertigkeit name="Nahkampf" wert="1"/>
      <Fertigkeit name="Verteidigung" wert="1"/>
	  
	  <Fertigkeit name="Darbietung" wert="2"/>
	  <Fertigkeit name="Beeinflussung" wert="-1"/>
	  <Fertigkeit name="Mythenkunde" wert="1"/>
	  <Fertigkeit name="Diplomatie" wert="2"/>
	  <Vorteil name="Angepasst (Dschungel)"/>
    </Variante>
	<Variante name="Borbaradianisch besetzte Gebiete (Tobrien, Ost-Darpatien, Warunk, Beilunk)">
	  <Attribut name="MU" wert="-1"/>
	  
	  <Fertigkeit name="Wahrnehmung" wert="1"/>
	  <Fertigkeit name="Feingefühl" wert="1"/>
	  <Fertigkeit name="Magiekunde" wert="1"/>
    </Variante>
  </Varianten>
  <Auswahl>
    <Fertigkeit name="Tierführung" wert="1"/>
