<Charakter>
  <Varianten>
    <Variante name="Hafenstädte und Städte an großen Flüssen (z.B. Elenvina, Ferdok, Festum, Harben, Havena, Perricum)">
	  <Fertigkeit name="Feingefühl" wert="1"/>
	  <Fertigkeit name="Beeinflussung" wert="1"/>
	  <Fertigkeit name="Jagd" wert="1"/>
	  <Fertigkeit name="Naturkunde" wert="1"/>
	  <Fertigkeit name="Seefahrt" wert="1"/>
	</Variante>
	<Variante name="Städte mit wichtigem Tempel / Pilgerstätte (Angbar, Gareth/Neu-Gareth, Rommilys)">
	  <Fertigkeit name="Beeinflussung" wert="2"/>
	  <Fertigkeit name="Naturkunde" wert="1"/>
	  <Fertigkeit name="Mythenkunde" wert="1"/>
	</Variante>
    <Variante name="Siedlerstädte des Nordens (Uhdenberg, Donnerbach, Riva, Lowangen, Norburg)">
	  <Fertigkeit name="Überleben" wert="1"/>
	  <Fertigkeit name="Grobhandwerk" wert="1"/>
	</Variante>
	<Variante name="Städtischer Adel">
	  <Vorteil name="Privilegien (Adel)"/>
	  <Fertigkeit name="Diplomatie" wert="2"/>
	  <Fertigkeit name="Straßenkunde" wert="-1"/>
	  <Vorteil name="Schriftkenntnis (Kusliker Zeichen)"/>
	</Variante>
	<Variante name="Kannemünde / Mhanerhaven">
	  <Fertigkeit name="Feingefühl" wert="1"/>
	  <Fertigkeit name="Beeinflussung" wert="1"/>
	  <Fertigkeit name="Naturkunde" wert="1"/>
	  <Fertigkeit name="Bildung" wert="1"/>
	  <Vorteil name="Kulturkunde (Tulamidenlande)"/>
	  <Vorteil name="Sprachkenntnis (Tulamidya)"/>
	</Variante>
    <Variante name="Flüchtlinge aus borbaradianisch besetzten Städten (z.B. Ysilia, Mendena, Ilsur, Warunk, Beilunk)">
	  <Attribut name="MU" wert="-1"/>
	  
	  <Fertigkeit name="Wahrnehmung" wert="1"/>
	  <Fertigkeit name="Feingefühl" wert="1"/>
	  <Fertigkeit name="Magiekunde" wert="1"/>
	</Variante>
  </Varianten>
  <Auswahl>
    <Fertigkeit name="Schusswaffen" wert="1"/>
    <Fertigkeit name="Wurfwaffen" wert="1"/>
  </Auswahl>
  <Auswahl>
    <Fertigkeit name="Feinhandwerk" wert="1"/>
    <Fertigkeit name="Grobhandwerk" wert="1"/>
  </Auswahl>
  <Auswahl varianten="4">
	<Fertigkeit name="Seefahrt" wert="1"/>
	<Fertigkeit name="Jagd" wert="1"/>
	<Fertigkeit name="Feinhandwerk" wert="1"/>
  </Auswahl>
  <Auswahl keine-varianten="2,4,5">
    <Vorteil name="Sprachkenntnis (Tulamidya)"/>
    <Vorteil name="Sprachkenntnis (Rogolan)"/>
    <Vorteil name="Sprachkenntnis (Thorwalsch)"/>
  </Auswahl>
  <Auswahl varianten="2">
    <Vorteil name="Sprachkenntnis (Nujuka)"/>
    <Vorteil name="Sprachkenntnis (Alaani)"/>
    <Vorteil name="Sprachkenntnis (Oloarkh)"/>
  </Auswahl>
  <Auswahl varianten="5">
    <Vorteil name="Sprachkenntnis (Tulamidya)"/>
    <Vorteil name="Sprachkenntnis (Rogolan)"/>
    <Vorteil name="Sprachkenntnis (Thorwalsch)"/>
    <Vorteil name="Sprachkenntnis (Zhayad)"/>
    <Vorteil name="Sprachkenntnis (Zhulchammaqra)"/>
  </Auswahl>
</Charakter>
